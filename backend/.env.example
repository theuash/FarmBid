# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017/farmbid_db
DB_NAME=farmbid_db

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Authentication
JWT_SECRET=your_super_secret_random_string_change_this_in_production
JWT_EXPIRES_IN=7d

# Razorpay Credentials
RAZORPAY_PAYMENT_LINK_BASE=https://razorpay.me/@your_vpa
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
NEXT_PUBLIC_UPI_ID=your_upi_vpa@axl

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# AI Integrations
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_key

# Demo Account Credentials
DEMO_BUYER_EMAIL=demo.buyer@farmbid.com
DEMO_BUYER_PASSWORD=demo123
DEMO_FARMER_PASSWORD=demo123
DEMO_AGENT_EMAIL=demo.agent@farmbid.com
DEMO_AGENT_PASSWORD=demo123
DEMO_ADMIN_EMAIL=demo.admin@farmbid.com
DEMO_ADMIN_PASSWORD=demo123

# WhatsApp Configuration
WHATSAPP_SESSION_PATH=./.wwebjs_auth
WHATSAPP_HEADLESS=false
PUPPETEER_EXECUTABLE_PATH=

# Polygon Escrow
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key
PLATFORM_PRIVATE_KEY=your_platform_wallet_private_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# App Webhook 

INTERNAL_WEBHOOK_SECRET=your_random_secret_string
